rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasPermission(permission) {
      return signedIn()
        && request.auth.token.permissions != null
        && request.auth.token.permissions.hasAny([permission]);
    }

    function workspaceMatches(workspaceId) {
      return signedIn() && request.auth.token.workspaceId == workspaceId;
    }

    function portalMatches(clientId) {
      return signedIn()
        && request.auth.token.portal == true
        && request.auth.token.clientId == clientId;
    }

    function canReadNetwork(workspaceId) {
      return workspaceMatches(workspaceId) && hasPermission("networks.view");
    }

    function canReadEndpoints(workspaceId) {
      return workspaceMatches(workspaceId) && hasPermission("endpoints.view");
    }

    function canReadEmployees(workspaceId) {
      return workspaceMatches(workspaceId) && hasPermission("employees.view");
    }

    function canManageEmployees(workspaceId) {
      return workspaceMatches(workspaceId) && (hasPermission("employees.create") || hasPermission("employees.update") || hasPermission("employees.archive"));
    }

    function employeeSelf(resourceData) {
      return signedIn() && resourceData.firebaseUid != null && resourceData.firebaseUid == request.auth.uid;
    }

    function canReadAttendance(workspaceId) {
      return workspaceMatches(workspaceId) && hasPermission("attendance.view");
    }

    function canReadFinance(workspaceId) {
      return workspaceMatches(workspaceId) && (
        hasPermission("finance.dashboard.view") || hasPermission("finance.reports.view") ||
        hasPermission("quotes.view") || hasPermission("invoices.view") || hasPermission("payments.view") ||
        hasPermission("expenses.view") || hasPermission("suppliers.view") || hasPermission("budgets.view")
      );
    }

    function canReadKnowledgeInternal(workspaceId) {
      return workspaceMatches(workspaceId) && hasPermission("knowledge.internal.view");
    }

    function canReadKnowledgeClient(data) {
      return data.workspaceId == request.auth.token.workspaceId
        && data.status == "PUBLISHED"
        && (data.visibility == "PUBLIC" || (data.visibility == "CLIENT" && portalMatches(data.clientId)));
    }

    match /workspaces/{workspaceId} {
      allow read: if workspaceMatches(workspaceId) || hasPermission("workspaces.manage");
      allow write: if hasPermission("workspaces.manage");
    }

    match /users/{userId} {
      allow read: if hasPermission("users.view") && workspaceMatches(resource.data.workspaceId);
      allow write: if hasPermission("users.edit") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /employees/{employeeId} {
      allow read: if canReadEmployees(resource.data.workspaceId) || employeeSelf(resource.data);
      allow create: if hasPermission("employees.create") && workspaceMatches(request.resource.data.workspaceId);
      allow update: if canManageEmployees(resource.data.workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.employeeNumber == resource.data.employeeNumber
        && request.resource.data.workEmail == resource.data.workEmail
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.accountState == resource.data.accountState
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /departments/{departmentId} {
      allow read: if canReadEmployees(resource.data.workspaceId);
      allow write: if hasPermission("departments.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /teams/{teamId} {
      allow read: if canReadEmployees(resource.data.workspaceId);
      allow write: if hasPermission("teams.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /jobTitles/{jobTitleId} {
      allow read: if canReadEmployees(resource.data.workspaceId);
      allow write: if hasPermission("job_titles.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /employeeContracts/{contractId} {
      allow read: if hasPermission("employee_contracts.view") && workspaceMatches(resource.data.workspaceId);
      allow write: if hasPermission("employee_contracts.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /employeeDocuments/{documentId} {
      allow read: if hasPermission("employee_documents.view") && workspaceMatches(resource.data.workspaceId);
      allow write: if hasPermission("employee_documents.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /employeeEmergencyContacts/{contactId} {
      allow read: if hasPermission("employee_emergency_contacts.view") && workspaceMatches(resource.data.workspaceId);
      allow write: if hasPermission("employee_emergency_contacts.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /employeeQualifications/{qualificationId} {
      allow read, update, delete: if hasPermission("employee_qualifications.manage") && workspaceMatches(resource.data.workspaceId);
      allow create: if hasPermission("employee_qualifications.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /employeeTraining/{trainingId} {
      allow read, update, delete: if hasPermission("employee_training.manage") && workspaceMatches(resource.data.workspaceId);
      allow create: if hasPermission("employee_training.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /onboardingTemplates/{templateId} {
      allow read, update, delete: if hasPermission("onboarding.manage") && workspaceMatches(resource.data.workspaceId);
      allow create: if hasPermission("onboarding.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /onboardingWorkflows/{workflowId} {
      allow read: if canReadEmployees(resource.data.workspaceId);
      allow write: if hasPermission("onboarding.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /onboardingTasks/{taskId} {
      allow read: if canReadEmployees(resource.data.workspaceId);
      allow write: if hasPermission("onboarding.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /offboardingTemplates/{templateId} {
      allow read, update, delete: if hasPermission("offboarding.manage") && workspaceMatches(resource.data.workspaceId);
      allow create: if hasPermission("offboarding.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /offboardingWorkflows/{workflowId} {
      allow read: if canReadEmployees(resource.data.workspaceId);
      allow write: if hasPermission("offboarding.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /offboardingTasks/{taskId} {
      allow read: if canReadEmployees(resource.data.workspaceId);
      allow write: if hasPermission("offboarding.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /employeeNotes/{noteId} {
      allow read: if hasPermission("employee_notes.view") && workspaceMatches(resource.data.workspaceId);
      allow create: if hasPermission("employee_notes.manage") && workspaceMatches(request.resource.data.workspaceId);
      allow update, delete: if hasPermission("employee_notes.manage") && workspaceMatches(resource.data.workspaceId);
    }

    match /employeeActivities/{activityId} {
      allow read: if hasPermission("employee_audit.view") && workspaceMatches(resource.data.workspaceId);
      allow write: if false;
    }

    match /employeeStatusHistory/{historyId} {
      allow read: if hasPermission("employee_audit.view") && workspaceMatches(resource.data.workspaceId);
      allow write: if false;
    }

    match /employeeManagerHistory/{historyId} {
      allow read: if hasPermission("employee_audit.view") && workspaceMatches(resource.data.workspaceId);
      allow write: if false;
    }

    match /employeeUniqueness/{key} {
      allow read, write: if false;
    }

    match /attendanceProfiles/{profileId} {
      allow read: if canReadAttendance(resource.data.workspaceId);
      allow create: if hasPermission("attendance.profiles.manage") && workspaceMatches(request.resource.data.workspaceId);
      allow update, delete: if hasPermission("attendance.profiles.manage") && workspaceMatches(resource.data.workspaceId);
    }

    match /workLocations/{locationId} {
      allow read: if canReadAttendance(resource.data.workspaceId);
      allow create: if hasPermission("attendance.locations.manage") && workspaceMatches(request.resource.data.workspaceId);
      allow update, delete: if hasPermission("attendance.locations.manage") && workspaceMatches(resource.data.workspaceId);
    }

    match /workSchedules/{scheduleId} {
      allow read: if canReadAttendance(resource.data.workspaceId);
      allow create: if hasPermission("attendance.schedules.manage") && workspaceMatches(request.resource.data.workspaceId);
      allow update, delete: if hasPermission("attendance.schedules.manage") && workspaceMatches(resource.data.workspaceId);
    }

    match /attendanceAssignments/{assignmentId} {
      allow read: if canReadAttendance(resource.data.workspaceId);
      allow write: if hasPermission("attendance.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /attendanceEvents/{eventId} {
      allow read: if canReadAttendance(resource.data.workspaceId);
      allow write: if false;
    }

    match /attendanceSessions/{sessionId} {
      allow read: if canReadAttendance(resource.data.workspaceId);
      allow write: if false;
    }

    match /attendanceBreaks/{breakId} {
      allow read: if canReadAttendance(resource.data.workspaceId);
      allow write: if false;
    }

    match /attendanceExceptions/{exceptionId} {
      allow read: if canReadAttendance(resource.data.workspaceId);
      allow create: if hasPermission("attendance.exceptions.manage") && workspaceMatches(request.resource.data.workspaceId);
      allow update: if hasPermission("attendance.approve") && workspaceMatches(resource.data.workspaceId);
      allow delete: if false;
    }

    match /attendanceApprovals/{approvalId} {
      allow read: if canReadAttendance(resource.data.workspaceId);
      allow write: if hasPermission("attendance.approve") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /timesheets/{timesheetId} {
      allow read: if canReadAttendance(resource.data.workspaceId);
      allow write: if hasPermission("attendance.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /overtimeRequests/{requestId} {
      allow read: if canReadAttendance(resource.data.workspaceId);
      allow write: if hasPermission("attendance.approve") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /attendanceIdempotency/{key} {
      allow read, write: if false;
    }

    match /attendanceLocks/{key} {
      allow read, write: if false;
    }

    function canReadProject(projectData) {
      return workspaceMatches(projectData.workspaceId) && hasPermission("projects.view");
    }

    function canReadClientProject(projectData) {
      return portalMatches(projectData.clientId) && projectData.clientPortalVisible == true;
    }

    match /projects/{projectId} {
      allow read: if canReadProject(resource.data) || canReadClientProject(resource.data);
      allow write: if false;
    }

    match /projectTasks/{taskId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("project_tasks.view");
      allow write: if false;
    }

    match /projectMembers/{memberId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("projects.view");
      allow write: if false;
    }

    match /projectMilestones/{milestoneId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("projects.view")
        || canReadClientProject(get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data) && resource.data.clientVisible == true;
      allow write: if false;
    }

    match /projectComments/{commentId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("projects.view")
        || canReadClientProject(get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data) && resource.data.visibility == "CLIENT_VISIBLE";
      allow write: if false;
    }

    match /projectFiles/{fileId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("projects.view")
        || canReadClientProject(get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data) && resource.data.clientVisible == true;
      allow write: if false;
    }

    match /projectTimeEntries/{entryId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("project_time.view");
      allow write: if false;
    }

    match /projectRisks/{riskId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("project_risks.manage");
      allow write: if false;
    }

    match /projectTaskDependencies/{dependencyId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("project_tasks.view");
      allow write: if false;
    }

    match /projectStatusHistory/{historyId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("projects.view");
      allow write: if false;
    }

    match /projectTaskStatusHistory/{historyId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("project_tasks.view");
      allow write: if false;
    }

    match /projectActivities/{activityId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("projects.view");
      allow write: if false;
    }

    match /projectHealthSnapshots/{snapshotId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("projects.view");
      allow write: if false;
    }

    match /projectTemplates/{templateId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && (hasPermission("projects.view") || hasPermission("project_templates.manage"));
      allow write: if hasPermission("project_templates.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /projectTemplateTasks/{taskId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("project_templates.manage");
      allow write: if hasPermission("project_templates.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /projectUniqueness/{key} {
      allow read, write: if false;
    }

    match /projectTaskUniqueness/{key} {
      allow read, write: if false;
    }

    match /projectTimerLocks/{key} {
      allow read, write: if false;
    }

    match /projectTicketLinks/{linkId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("projects.view");
      allow write: if false;
    }

    match /projectAssetLinks/{linkId} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("projects.view");
      allow write: if false;
    }

    match /roles/{roleId} {
      allow read: if hasPermission("roles.view") && workspaceMatches(resource.data.workspaceId);
      allow write: if hasPermission("roles.manage");
    }

    match /permissions/{permissionId} {
      allow read: if hasPermission("roles.view");
      allow write: if hasPermission("roles.manage");
    }

    match /tickets/{ticketId} {
      allow read: if hasPermission("tickets.view") && workspaceMatches(resource.data.workspaceId)
        || (signedIn() && resource.data.requesterId == request.auth.uid)
        || portalMatches(resource.data.clientId);
      allow write: if hasPermission("tickets.edit") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /ticketComments/{commentId} {
      allow read: if hasPermission("tickets.view") || portalMatches(resource.data.clientId);
      allow write: if hasPermission("tickets.comment");
    }

    match /ticketAttachments/{attachmentId} {
      allow read: if hasPermission("tickets.view") || portalMatches(resource.data.clientId);
      allow write: if hasPermission("tickets.attach");
    }

    match /slaPolicies/{policyId} {
      allow read: if hasPermission("slaPolicies.view") && workspaceMatches(resource.data.workspaceId);
      allow write: if hasPermission("slaPolicies.manage");
    }

    match /slaEvents/{eventId} {
      allow read: if hasPermission("slaPolicies.view") || hasPermission("escalations.view");
      allow write: if false;
    }

    match /escalations/{escalationId} {
      allow read: if hasPermission("escalations.view");
      allow write: if hasPermission("escalations.manage");
    }

    match /automationRules/{ruleId} {
      allow read: if hasPermission("automation.view");
      allow write: if hasPermission("automation.manage");
    }

    match /automationExecutions/{executionId} {
      allow read: if hasPermission("automation.view");
      allow write: if false;
    }

    match /clients/{clientId} {
      allow read: if hasPermission("clients.view") && workspaceMatches(resource.data.workspaceId)
        || portalMatches(clientId);
      allow write: if hasPermission("clients.update") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /clientContacts/{contactId} {
      allow read: if hasPermission("contacts.manage") || portalMatches(resource.data.clientId);
      allow write: if hasPermission("contacts.manage");
    }

    match /clientSites/{siteId} {
      allow read: if hasPermission("sites.manage") || portalMatches(resource.data.clientId);
      allow write: if hasPermission("sites.manage");
    }

    match /contracts/{contractId} {
      allow read: if hasPermission("contracts.view") || portalMatches(resource.data.clientId);
      allow write: if hasPermission("contracts.manage");
    }

    match /supportAgreements/{agreementId} {
      allow read: if hasPermission("support_agreements.manage") || portalMatches(resource.data.clientId);
      allow write: if hasPermission("support_agreements.manage");
    }

    match /billingProfiles/{billingProfileId} {
      allow read: if hasPermission("billing.view") || portalMatches(resource.data.clientId);
      allow write: if hasPermission("billing.manage");
    }

    match /clientNotes/{noteId} {
      allow read: if hasPermission("clients.view") || portalMatches(resource.data.clientId);
      allow write: if hasPermission("clients.update");
    }

    match /clientFiles/{fileId} {
      allow read: if hasPermission("client_files.manage") || portalMatches(resource.data.clientId);
      allow write: if hasPermission("client_files.manage");
    }

    match /portalInvitations/{invitationId} {
      allow read: if hasPermission("portal_access.manage") || portalMatches(resource.data.clientId);
      allow write: if hasPermission("portal_access.manage");
    }

    match /portalAccounts/{accountId} {
      allow read: if hasPermission("portal_access.manage") || portalMatches(resource.data.clientId);
      allow write: if hasPermission("portal_access.manage");
    }

    match /assets/{assetId} {
      allow read: if hasPermission("assets.view") && workspaceMatches(resource.data.workspaceId);
      allow create: if hasPermission("assets.create") && workspaceMatches(request.resource.data.workspaceId);
      allow update: if hasPermission("assets.update")
        && workspaceMatches(request.resource.data.workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.assetTag == resource.data.assetTag
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdById == resource.data.createdById;
      allow delete: if hasPermission("assets.archive");
    }

    match /assetTypes/{assetTypeId} {
      allow read: if hasPermission("assets.view") && workspaceMatches(resource.data.workspaceId);
      allow write: if hasPermission("assetTypes.manage");
    }

    match /assetAssignments/{assignmentId} {
      allow read: if hasPermission("assets.view");
      allow write: if false;
    }

    match /assetEvents/{eventId} {
      allow read: if hasPermission("asset_audit.view") || hasPermission("assets.view");
      allow write: if false;
    }

    match /assetSoftware/{softwareId} {
      allow read: if hasPermission("asset_software.manage") || hasPermission("assets.view");
      allow write: if false;
    }

    match /softwareLicences/{licenceId} {
      allow read: if hasPermission("asset_licences.view") || hasPermission("assets.view");
      allow write: if hasPermission("asset_licences.manage");
    }

    match /licenceAssignments/{assignmentId} {
      allow read: if hasPermission("asset_licences.view");
      allow write: if false;
    }

    match /assetMaintenance/{maintenanceId} {
      allow read: if hasPermission("asset_maintenance.manage") || hasPermission("assets.view");
      allow write: if false;
    }

    match /assetWarranties/{warrantyId} {
      allow read: if hasPermission("assets.view");
      allow write: if false;
    }

    match /assetFiles/{fileId} {
      allow read: if hasPermission("asset_files.manage") || hasPermission("assets.view");
      allow write: if hasPermission("asset_files.manage");
    }

    match /assetImports/{importId} {
      allow read: if hasPermission("assets.import");
      allow write: if false;
    }

    match /assetTagCounters/{counterId} {
      allow read, write: if false;
    }

    match /assetHealthSnapshots/{snapshotId} {
      allow read: if hasPermission("asset_audit.view") || hasPermission("assets.view");
      allow write: if false;
    }

    match /networkEnvironments/{environmentId} {
      allow read: if canReadNetwork(resource.data.workspaceId);
      allow create: if hasPermission("networks.create") && workspaceMatches(request.resource.data.workspaceId);
      allow update: if hasPermission("networks.update")
        && workspaceMatches(resource.data.workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.siteId == resource.data.siteId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdById == resource.data.createdById;
      allow delete: if false;
    }

    match /networkDevices/{deviceId} {
      allow read: if canReadNetwork(resource.data.workspaceId);
      allow create, update: if hasPermission("network_devices.manage") && workspaceMatches(request.resource.data.workspaceId);
      allow delete: if false;
    }

    match /endpoints/{endpointId} {
      allow read: if canReadEndpoints(resource.data.workspaceId);
      allow create, update, delete: if false;
    }

    match /endpointEnrollments/{enrollmentId} {
      allow read: if hasPermission("endpoints.enrol") && workspaceMatches(resource.data.workspaceId);
      allow create, update, delete: if false;
    }

    match /endpointCredentials/{credentialId} {
      allow read, write: if false;
    }

    match /endpointAudits/{auditId} {
      allow read: if hasPermission("endpoint_raw_audits.view") && workspaceMatches(resource.data.workspaceId);
      allow create, update, delete: if false;
    }

    match /endpointSnapshots/{snapshotId} {
      allow read: if canReadEndpoints(resource.data.workspaceId);
      allow write: if false;
    }

    match /endpointChanges/{changeId} {
      allow read: if canReadEndpoints(resource.data.workspaceId);
      allow write: if false;
    }

    match /networkAlerts/{alertId} {
      allow read: if hasPermission("network_alerts.view") && workspaceMatches(resource.data.workspaceId);
      allow write: if false;
    }

    match /networkAlertEvents/{eventId} {
      allow read: if hasPermission("network_alerts.view") && workspaceMatches(resource.data.workspaceId);
      allow write: if false;
    }

    match /monitoringPolicies/{policyId} {
      allow read: if canReadNetwork(resource.data.workspaceId);
      allow write: if hasPermission("monitoring_policies.manage") && workspaceMatches(request.resource.data.workspaceId);
    }

    match /auditIngestionLogs/{logId} {
      allow read: if hasPermission("endpoint_raw_audits.view") && workspaceMatches(resource.data.workspaceId);
      allow write: if false;
    }

    match /endpointCommands/{commandId} {
      allow read: if hasPermission("endpoints.audit") && workspaceMatches(resource.data.workspaceId);
      allow write: if false;
    }

    match /endpointCommandResults/{resultId} {
      allow read: if hasPermission("endpoints.audit") && workspaceMatches(resource.data.workspaceId);
      allow write: if false;
    }

    match /endpointRateLimits/{rateLimitId} {
      allow read, write: if false;
    }

    match /endpointNonces/{nonceId} {
      allow read, write: if false;
    }

    match /networkSavedViews/{viewId} {
      allow read: if hasPermission("endpoints.view") && workspaceMatches(resource.data.workspaceId) && resource.data.userId == request.auth.uid;
      allow create: if hasPermission("endpoints.view") && workspaceMatches(request.resource.data.workspaceId) && request.resource.data.userId == request.auth.uid;
      allow update: if hasPermission("endpoints.view") && workspaceMatches(resource.data.workspaceId) && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if hasPermission("endpoints.view") && workspaceMatches(resource.data.workspaceId) && resource.data.userId == request.auth.uid;
    }

    match /networkRetentionRuns/{runId} {
      allow read: if hasPermission("audit.view");
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read, write: if signedIn() && request.auth.uid == resource.data.userId;
    }

    match /auditLogs/{logId} {
      allow read: if hasPermission("audit.view");
      allow write: if false;
    }

    match /settings/{settingId} {
      allow read: if hasPermission("settings.view");
      allow write: if hasPermission("settings.manage");
    }

    match /financeSettings/{id} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("finance.settings.manage");
      allow write: if false;
    }
    match /clientBillingProfiles/{id} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("finance.settings.manage");
      allow write: if false;
    }
    match /quotes/{id} {
      allow read: if canReadFinance(resource.data.workspaceId);
      allow write: if false;
    }
    match /invoices/{id} {
      allow read: if canReadFinance(resource.data.workspaceId);
      allow write: if false;
    }
    match /creditNotes/{id} {
      allow read: if canReadFinance(resource.data.workspaceId);
      allow write: if false;
    }
    match /payments/{id} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("payments.view");
      allow write: if false;
    }
    match /paymentAllocations/{id} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("payments.view");
      allow write: if false;
    }
    match /expenses/{id} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("expenses.view");
      allow write: if false;
    }
    match /suppliers/{id} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("suppliers.view");
      allow write: if false;
    }
    match /purchaseOrders/{id} {
      allow read: if canReadFinance(resource.data.workspaceId);
      allow write: if false;
    }
    match /purchaseReceipts/{id} {
      allow read: if canReadFinance(resource.data.workspaceId);
      allow write: if false;
    }
    match /budgets/{id} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("budgets.view");
      allow write: if false;
    }
    match /financialApprovals/{id} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("financial_audit.view");
      allow write: if false;
    }
    match /financialDocuments/{id} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("financial_documents.view");
      allow write: if false;
    }
    match /financialActivities/{id} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("financial_audit.view");
      allow write: if false;
    }
    match /financialExports/{id} {
      allow read: if workspaceMatches(resource.data.workspaceId) && hasPermission("finance.exports.create");
      allow write: if false;
    }
    match /financialNumberCounters/{id} {
      allow read, write: if false;
    }

    match /knowledgeArticles/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId) || (signedIn() && canReadKnowledgeClient(resource.data));
      allow write: if false;
    }
    match /knowledgeCategories/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId) || (signedIn() && canReadKnowledgeClient(resource.data));
      allow write: if false;
    }
    match /knowledgeTags/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId);
      allow write: if false;
    }
    match /knowledgeRevisions/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId);
      allow write: if false;
    }
    match /knowledgeReviews/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId);
      allow write: if false;
    }
    match /knowledgeReviewComments/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId);
      allow write: if false;
    }
    match /knowledgeFeedback/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId);
      allow write: if false;
    }
    match /knowledgeAttachments/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId) || (signedIn() && canReadKnowledgeClient(resource.data));
      allow write: if false;
    }
    match /policyAcknowledgements/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId) || (signedIn() && resource.data.userId == request.auth.uid && workspaceMatches(resource.data.workspaceId) && hasPermission("knowledge.acknowledgements.view"));
      allow write: if false;
    }
    match /knowledgeActivities/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId);
      allow write: if false;
    }
    match /knowledgeViews/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId);
      allow write: if false;
    }
    match /knowledgeSearchEvents/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId);
      allow write: if false;
    }
    match /knowledgeLinkChecks/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId);
      allow write: if false;
    }
    match /knowledgeTicketLinks/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId);
      allow write: if false;
    }
    match /knowledgeAssetLinks/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId);
      allow write: if false;
    }
    match /knowledgeNetworkLinks/{id} {
      allow read: if canReadKnowledgeInternal(resource.data.workspaceId);
      allow write: if false;
    }
    match /knowledgeArticleUniqueness/{id} { allow read, write: if false; }
    match /knowledgeSlugUniqueness/{id} { allow read, write: if false; }
    match /policyAcknowledgementUniqueness/{id} { allow read, write: if false; }
    match /knowledgeImportJobs/{id} { allow read: if canReadKnowledgeInternal(resource.data.workspaceId); allow write: if false; }
    match /knowledgeSavedViews/{id} { allow read: if canReadKnowledgeInternal(resource.data.workspaceId); allow write: if false; }
    match /knowledgeJobRuns/{id} { allow read: if canReadKnowledgeInternal(resource.data.workspaceId); allow write: if false; }
    match /knowledgeClientAssignments/{id} { allow read: if canReadKnowledgeInternal(resource.data.workspaceId); allow write: if false; }
    match /knowledgeArticleTemplates/{id} { allow read: if canReadKnowledgeInternal(resource.data.workspaceId); allow write: if false; }
    match /knowledgeCollectionItems/{id} { allow read: if canReadKnowledgeInternal(resource.data.workspaceId); allow write: if false; }
    match /knowledgeCredentialReferences/{id} { allow read: if canReadKnowledgeInternal(resource.data.workspaceId) && hasPermission("knowledge.credential_references.view"); allow write: if false; }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
