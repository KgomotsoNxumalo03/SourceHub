rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function hasPermission(permission) {
      return signedIn()
        && request.auth.token.permissions != null
        && request.auth.token.permissions.hasAny([permission]);
    }

    function workspaceMatches(workspaceId) {
      return signedIn() && request.auth.token.workspaceId == workspaceId;
    }

    function tenantMatches(tenantId) {
      return signedIn() && request.auth.token.tenantId == tenantId && request.auth.token.workspaceId == tenantId;
    }

    function portalMatches(clientId) {
      return signedIn()
        && request.auth.token.portal == true
        && request.auth.token.clientId == clientId;
    }

    match /workspaces/{workspaceId}/clients/{clientId}/files/{fileName} {
      allow read: if hasPermission("client_files.manage") || portalMatches(clientId);
      allow write: if hasPermission("client_files.manage") && workspaceMatches(workspaceId);
    }

    match /workspaces/{workspaceId}/assets/{assetId}/{fileName} {
      allow read: if hasPermission("assets.view") || hasPermission("asset_files.manage");
      allow write: if hasPermission("asset_files.manage") && workspaceMatches(workspaceId);
    }

    match /workspaces/{workspaceId}/endpoints/{endpointId}/{fileName} {
      allow read: if hasPermission("endpoints.view") && workspaceMatches(workspaceId);
      allow write: if hasPermission("endpoints.audit") && workspaceMatches(workspaceId)
        && request.resource.size < 4 * 1024 * 1024;
    }

    match /workspaces/{workspaceId}/employees/{employeeId}/documents/{fileName} {
      allow read: if workspaceMatches(workspaceId) && hasPermission("employee_documents.view");
      allow write: if workspaceMatches(workspaceId) && hasPermission("employee_documents.manage")
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches("application/pdf|image/.*|text/plain|application/vnd.openxmlformats-officedocument.*");
    }

    match /workspaces/{workspaceId}/tickets/{ticketReference}/files/{fileName} {
      allow read: if hasPermission("tickets.view");
      allow write: if hasPermission("tickets.attach") && workspaceMatches(workspaceId);
    }

    match /workspaces/{workspaceId}/projects/{projectId}/{fileName} {
      allow read: if workspaceMatches(workspaceId) && hasPermission("projects.view")
        || portalMatches(get(/databases/(default)/documents/projects/$(projectId)).data.clientId)
          && get(/databases/(default)/documents/projects/$(projectId)).data.clientPortalVisible == true;
      allow write: if workspaceMatches(workspaceId) && hasPermission("project_files.manage")
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches("image/.*|application/pdf|text/plain|application/zip|application/x-zip-compressed|application/vnd.openxmlformats-officedocument.*");
    }

    match /workspaces/{workspaceId}/finance/{documentType}/{documentId}/{fileName} {
      allow read: if workspaceMatches(workspaceId) && hasPermission("financial_documents.view");
      allow write: if workspaceMatches(workspaceId) && hasPermission("financial_documents.manage")
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches("application/pdf|image/.*|text/plain|application/zip|application/x-zip-compressed|application/vnd.openxmlformats-officedocument.*");
    }

    match /workspaces/{workspaceId}/knowledge/{articleId}/{fileName} {
      allow read: if workspaceMatches(workspaceId) && hasPermission("knowledge.internal.view")
        || (signedIn() && get(/databases/(default)/documents/knowledgeArticles/$(articleId)).data.status == "PUBLISHED"
          && get(/databases/(default)/documents/knowledgeArticles/$(articleId)).data.visibility == "CLIENT"
          && portalMatches(get(/databases/(default)/documents/knowledgeArticles/$(articleId)).data.clientId));
      allow write: if workspaceMatches(workspaceId) && hasPermission("knowledge.files.manage")
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches("image/.*|application/pdf|text/plain|application/zip|application/x-zip-compressed|application/vnd.openxmlformats-officedocument.*");
    }

    match /workspaces/{workspaceId}/reports/exports/{exportId}/{fileName} {
      allow read: if workspaceMatches(workspaceId)
        && (hasPermission("reports.manage") || get(/databases/(default)/documents/reportExports/$(exportId)).data.requestedBy == request.auth.uid)
        && get(/databases/(default)/documents/reportExports/$(exportId)).data.status == "COMPLETED";
      allow write: if false;
    }

    match /workspaces/{workspaceId}/mobile/{userId}/{fileName} {
      allow read: if workspaceMatches(workspaceId) && request.auth.uid == userId && hasPermission("mobile.access");
      allow write: if workspaceMatches(workspaceId) && request.auth.uid == userId
        && (hasPermission("mobile.camera.use") || hasPermission("mobile.tickets.manage"))
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches("image/.*|application/pdf|text/plain|application/vnd.openxmlformats-officedocument.*");
    }

    // Enterprise backup and export objects are managed by Admin SDK/Functions only.
    match /workspaces/{workspaceId}/enterprise/{allPaths=**} {
      allow read: if workspaceMatches(workspaceId) && hasPermission("backups.view");
      allow write: if false;
    }

    match /workspaces/{tenantId}/commercial/{allPaths=**} {
      allow read: if tenantMatches(tenantId) && (hasPermission("tenant.exports.manage") || hasPermission("tenant.branding.manage"));
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
